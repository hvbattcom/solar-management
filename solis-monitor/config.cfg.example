[SolisInverter]
# Solis Inverter Configuration File

# IP address of the logger device
inverter_ip = <logger_ip>

# Optional; 502 is common for newer S2-WL-ST, 8899 for some older loggers
inverter_port = 502

# Modbus device id / unit id
slave_id = 1

# Expected inverter serial – if mismatch, output is suppressed and error returned
# Leave empty to skip serial check
serial = <logger_serial>

# Inverter rated power in kW – used to calculate load percentages
inverter_power_kw = 30

# Number of physical MPPT inputs (1-4) – limits PV string reporting; unused strings are suppressed
mppt_count = 4

# default_sanity_ranges.cfg is loaded first; any key set here overrides it
# Example: uncomment to accept all-zero grid readings when grid is physically off
# zeros_ok_grid = true

[SolisAPI]
# Bind address and port for solis-api.py (also used by dispatch.py to reach it)
host = 0.0.0.0
port = 5000
