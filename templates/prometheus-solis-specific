# Solis-specific Prometheus metrics v2
# Appended to prometheus2 output; covers registers not present on generic inverters.

# ── Battery BMS ───────────────────────────────────────────────────────────────

# HELP battery_voltage_bms_v Battery BMS reported voltage volts (per-pack, not total)
# TYPE battery_voltage_bms_v gauge
battery_voltage_bms_v{brand="{{ brand }}",serial="{{ serial }}"} {{ battery_voltage_bms_v }}

# HELP battery_current_bms_a Battery BMS current amps
# TYPE battery_current_bms_a gauge
battery_current_bms_a{brand="{{ brand }}",serial="{{ serial }}"} {{ battery_current_bms_a }}

# HELP battery_charge_limit_a BMS charge current limit amps
# TYPE battery_charge_limit_a gauge
battery_charge_limit_a{brand="{{ brand }}",serial="{{ serial }}"} {{ battery_charge_current_limit_bms_a }}

# HELP battery_discharge_limit_a BMS discharge current limit amps
# TYPE battery_discharge_limit_a gauge
battery_discharge_limit_a{brand="{{ brand }}",serial="{{ serial }}"} {{ battery_discharge_current_limit_bms_a }}

# HELP battery_fault_status_bms BMS fault status register (decoded as integer)
# TYPE battery_fault_status_bms gauge
battery_fault_status_bms{brand="{{ brand }}",serial="{{ serial }}",register="1"} {{ battery_fault_status_1_bms_int }}
battery_fault_status_bms{brand="{{ brand }}",serial="{{ serial }}",register="2"} {{ battery_fault_status_2_bms_int }}

# ── Instantaneous Load ────────────────────────────────────────────────────────

# HELP household_load_power_w Household load instantaneous power watts
# TYPE household_load_power_w gauge
household_load_power_w{brand="{{ brand }}",serial="{{ serial }}"} {{ household_load_power_w }}

# HELP ac_grid_port_power_w AC grid port power watts (inverter-side, not CT)
# TYPE ac_grid_port_power_w gauge
ac_grid_port_power_w{brand="{{ brand }}",serial="{{ serial }}"} {{ ac_grid_port_power_w }}

